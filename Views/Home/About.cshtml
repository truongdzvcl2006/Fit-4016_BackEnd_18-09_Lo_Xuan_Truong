@{
    Layout = "~/Views/Home/_HomeLayout.cshtml";
    ViewData["Title"] = "Dự án";
}




<!-- INTRO -->
<section class="intro-section">
    <div class="container">

        <div class="section-title">
            <h2>Giới thiệu về hệ thống</h2>
        </div>

        <div class="row align-items-center">

            <div class="col-md-6 animate-on-scroll slide-in-left">
                <img src="https://images.unsplash.com/photo-1497366216548-37526070297c"
                     class="img-fluid rounded shadow">
            </div>

            <div class="col-md-6 animate-on-scroll slide-in-right">

                <h3>Sàn giao dịch bất động sản thông minh</h3>

                <p>
                    Website sàn giao dịch bất động sản được xây dựng nhằm cung cấp
                    nền tảng trực tuyến giúp khách hàng tìm kiếm, mua bán và đầu tư
                    bất động sản một cách dễ dàng và hiệu quả.
                </p>

                <p>
                    Hệ thống cho phép người dùng truy cập thông tin chi tiết về các
                    loại bất động sản như căn hộ, nhà phố, đất nền và các dự án
                    đầu tư tiềm năng. Mọi dữ liệu được cập nhật liên tục để đảm
                    bảo tính minh bạch và chính xác.
                </p>

                <p>
                    Với giao diện hiện đại và thân thiện, website giúp người dùng
                    nhanh chóng tìm được bất động sản phù hợp với nhu cầu và ngân sách.
                </p>

            </div>

        </div>
    </div>
</section>


<!-- GIÁ TRỊ -->
<section class="card-section">
    <div class="container">

        <div class="section-title">
            <h2>Giá trị cốt lõi</h2>
        </div>

        <div class="row">

            <div class="col-md-4">
                <div class="custom-card text-center p-4">
                    <h4>Uy tín</h4>
                    <p>
                        Cam kết cung cấp thông tin bất động sản minh bạch,
                        chính xác và đáng tin cậy cho mọi khách hàng.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="custom-card text-center p-4">
                    <h4>Công nghệ</h4>
                    <p>
                        Ứng dụng công nghệ hiện đại để nâng cao trải nghiệm
                        tìm kiếm và giao dịch bất động sản trực tuyến.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="custom-card text-center p-4">
                    <h4>Kết nối</h4>
                    <p>
                        Tạo cầu nối giữa người mua, người bán và nhà đầu tư
                        bất động sản trên cùng một nền tảng.
                    </p>
                </div>
            </div>

        </div>

    </div>
</section>


<!-- COMPANY STATS -->
<section class="card-section">
    <div class="container">

        <div class="row">

            <div class="col-md-12">
                <div class="custom-card company-card">

                    <div class="card-body text-center">

                        <h3 class="card-title">Thành tựu của chúng tôi</h3>

                        <p class="card-text">
                            Nền tảng giao dịch bất động sản của chúng tôi đã
                            kết nối hàng nghìn khách hàng và nhà đầu tư trên
                            toàn quốc.
                        </p>

                        <div class="stats">

                            <div class="stat-item">
                                <div class="stat-number">1500+</div>
                                <div class="stat-label">Bất động sản</div>
                            </div>

                            <div class="stat-item">
                                <div class="stat-number">800+</div>
                                <div class="stat-label">Khách hàng</div>
                            </div>

                            <div class="stat-item">
                                <div class="stat-number">120+</div>
                                <div class="stat-label">Dự án</div>
                            </div>

                            <div class="stat-item">
                                <div class="stat-number">50+</div>
                                <div class="stat-label">Đối tác</div>
                            </div>

                        </div>

                    </div>

                </div>
            </div>

        </div>

    </div>
</section>
