<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Real Estate Auction</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css">
        @await RenderSectionAsync("Styles", required: false)
    </head>

    <body>
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
            <div class="container">
                <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                    <i class="fas fa-rocket me-2"></i>
                    <span class="logo-text">Brand</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Home")">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("About", "Home")">Giới thiệu</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Dịch vụ
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#">Bất động sản</a></li>
                                <li><a class="dropdown-item" href="#">Nhà</a></li>
                                <li><a class="dropdown-item" href="#">Văn phòng cho thuê</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="#">Xem tất cả</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Projects", "Home")">Dự án</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Auction", "Home")">Đấu Giá</a>
                        </li>

                        @{
                            var userId = Context.Session.GetInt32("UserId");
                            var userName = Context.Session.GetString("UserName");
                            var userEmail = Context.Session.GetString("UserEmail");
                            var userRoleId = Context.Session.GetInt32("UserRoleId");
                        }

                        @if (userId != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle"></i> @userName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="@Url.Action("Profile", "Account")">
                                            <i class="fas fa-id-card"></i> Thông tin cá nhân
                                        </a>
                                    </li>
                                    @if (userRoleId == 1)
                                    {
                                        <li>
                                            <a class="dropdown-item" href="@Url.Action("Index", "Admin")">
                                                <i class="fas fa-cog"></i> Quản trị Admin
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")">
                                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-cta" href="@Url.Action("Login", "Account")">
                                    <i class="fas fa-sign-in-alt"></i> Đăng Nhập | Đăng Ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Phần giới thiệu hero section -->
        <section class="hero-section">
            <img src="https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80"
                 alt="Hình nền giới thiệu" class="hero-image">
            <div class="hero-overlay"></div>
            <div class="container">
                <div class="hero-content">
                    <h1 class="hero-title">Chào mừng đến với Website của chúng tôi</h1>
                    <p class="hero-text">
                        Chúng tôi cung cấp những ngôi nhà và căn phòng được thiết kế đẹp đẽ, phù hợp với thẩm mĩ của khách hàng.
                        Với hơn 10 năm hoạt động trong ngành, chúng tôi tự hào mang đến cho khách hàng những sản phẩm
                        và dịch vụ chất lượng cao nhất.
                    </p>
                    <div class="hero-btns">
                        <a href="#" class="btn btn-primary hero-btn">Tìm hiểu thêm</a>
                        <a href="#" class="btn btn-outline-light hero-btn">Liên hệ ngay</a>
                    </div>
                </div>
            </div>
        </section>

        <div>
            @RenderBody()
        </div>

        <!-- Footer Section -->
        <footer class="footer-section bg-dark text-white pt-5 pb-4">
            <div class="container">
                <div class="row g-4">
                    <!-- Column 1: Giới thiệu -->
                    <div class="col-lg-4 col-md-6 mb-4 mb-lg-0 animate-on-scroll fade-in">
                        <div class="footer-logo mb-3">
                            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                                <i class="fas fa-rocket me-2"></i>
                                <span class="logo-text">Brand</span>
                            </a>
                        </div>
                        <p class="mb-3">Công ty hàng đầu trong lĩnh vực bất động sản với hơn 15 năm kinh nghiệm, mang đến những giải pháp tối ưu cho khách hàng.</p>
                        <div class="social-icons">
                            <a href="#" class="text-white me-2"><i class="fab fa-facebook-f"></i></a>
                            <a href="#" class="text-white me-2"><i class="fab fa-twitter"></i></a>
                            <a href="#" class="text-white me-2"><i class="fab fa-linkedin-in"></i></a>
                            <a href="#" class="text-white me-2"><i class="fab fa-instagram"></i></a>
                            <a href="#" class="text-white"><i class="fab fa-youtube"></i></a>
                        </div>
                    </div>

                    <!-- Column 2: Liên kết nhanh -->
                    <div class="col-lg-2 col-md-6 mb-4 mb-lg-0 animate-on-scroll fade-in" style="transition-delay: 0.1s">
                        <h5 class="text-uppercase mb-4">Liên kết nhanh</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2"><a href="@Url.Action("Index", "Home")" class="text-white text-decoration-none">Trang chủ</a></li>
                            <li class="mb-2"><a href="@Url.Action("About", "Home")" class="text-white text-decoration-none">Giới thiệu</a></li>
                            <li class="mb-2"><a href="@Url.Action("Projects", "Home")" class="text-white text-decoration-none">Dự án</a></li>
                            <li class="mb-2"><a href="#" class="text-white text-decoration-none">Dịch vụ</a></li>
                            <li class="mb-2"><a href="#" class="text-white text-decoration-none">Tin tức</a></li>
                            <li><a href="#" class="text-white text-decoration-none">Liên hệ</a></li>
                        </ul>
                    </div>

                    <!-- Column 3: Dịch vụ -->
                    <div class="col-lg-3 col-md-6 mb-4 mb-lg-0 animate-on-scroll fade-in" style="transition-delay: 0.2s">
                        <h5 class="text-uppercase mb-4">Dịch vụ</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2"><a href="#" class="text-white text-decoration-none">Mua bán nhà đất</a></li>
                            <li class="mb-2"><a href="#" class="text-white text-decoration-none">Cho thuê văn phòng</a></li>
                            <li class="mb-2"><a href="#" class="text-white text-decoration-none">Tư vấn đầu tư</a></li>
                            <li class="mb-2"><a href="#" class="text-white text-decoration-none">Thiết kế nội thất</a></li>
                            <li class="mb-2"><a href="#" class="text-white text-decoration-none">Quản lý bất động sản</a></li>
                            <li><a href="#" class="text-white text-decoration-none">Dịch vụ pháp lý</a></li>
                        </ul>
                    </div>

                    <!-- Column 4: Liên hệ -->
                    <div class="col-lg-3 col-md-6 animate-on-scroll fade-in" style="transition-delay: 0.3s">
                        <h5 class="text-uppercase mb-4">Liên hệ</h5>
                        <ul class="list-unstyled">
                            <li class="mb-3 d-flex">
                                <i class="fas fa-map-marker-alt me-3 mt-1"></i>
                                <span>111, đường Phú Lương, Phường Quang Lãm, Hà Đông, Hà Nội</span>
                            </li>
                            <li class="mb-3 d-flex">
                                <i class="fas fa-phone-alt me-3 mt-1"></i>
                                <div>
                                    <p class="mb-0">Hotline: <a href="tel:0900123456" class="text-white text-decoration-none">0900 0509 2006</a></p>
                                    <p class="mb-0">Điện thoại: <a href="tel:0281234567" class="text-white text-decoration-none">0857 243 819</a></p>
                                </div>
                            </li>
                            <li class="d-flex">
                                <i class="fas fa-envelope me-3 mt-1"></i>
                                <div>
                                    <p class="mb-0">Email: <a href="mailto:info@realestate.com" class="text-white text-decoration-none">truong72.minecraft@gmail.com</a></p>
                                    <p class="mb-0">Hỗ trợ: <a href="mailto:support@realestate.com" class="text-white text-decoration-none">chamsockhachhangBRAND@gmail.com</a></p>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>

                <hr class="my-4 bg-light">

                <!-- Bottom Footer -->
                <div class="row align-items-center">
                    <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                        <p class="mb-0">&copy; 2023 REAL ESTATE. All rights reserved.</p>
                    </div>
                    <div class="col-md-6 text-center text-md-end">
                        <div class="footer-links">
                            <a href="#" class="text-white text-decoration-none me-3">Chính sách bảo mật</a>
                            <a href="#" class="text-white text-decoration-none me-3">Điều khoản sử dụng</a>
                            <a href="#" class="text-white text-decoration-none">Sitemap</a>
                        </div>
                    </div>
                </div>
            </div>
        </footer>

        <!-- Scripts -->
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js"></script>
        @RenderSection("Scripts", required: false)
    </body>
</html>