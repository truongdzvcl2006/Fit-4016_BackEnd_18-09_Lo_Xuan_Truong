@{
    Layout = "_HomeLayout";
    ViewData["Title"] = "Trang chủ";
}

<link rel="stylesheet" href="~/css/site.css">




    <section class="card-section">
        <div class="container">
            <div class="section-title">
                <h2>Giới Thiệu Công Ty Chúng Tôi</h2>
                <br><br>
                <p>Khám phá những điều tuyệt vời về công ty của chúng tôi</p>
            </div>
            
            <div class="row">
                <!-- Card Sản Phẩm -->
                <div class="col-md-4">
                    <div class="card custom-card product-card">
                        <span class="badge">Mới</span>
                        <img src="https://images.unsplash.com/photo-1551434678-e076c223a692?ixlib=rb-1.2.1&auto=format&fit=crop&w=800&q=80" class="card-img-top" alt="Sản phẩm">
                        <div class="card-body">
                            <h5 class="card-title">Sản Phẩm Cao Cấp</h5>
                            <p class="card-text">Giải pháp công nghệ hiện đại nhất với thiết kế tối ưu cho trải nghiệm người dùng tuyệt vời.</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="price">Chỉ từ: 129.990.000đ</span>
                                <button class="btn btn-outline-primary">Xem chi tiết</button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Card Nhân Viên Tập Thể -->
                <div class="col-md-4">
                    <div class="card custom-card team-card">
                        <img src="~/Images/nv1.jpg" class="team-img" alt="Toàn bộ nhân viên">
                        <div class="card-body">
                            <h5 class="card-title">Đội Ngũ Nhân Viên</h5>
                            <p class="card-text">Đội ngũ chuyên nghiệp với nhiều năm kinh nghiệm, luôn sẵn sàng mang đến giải pháp tốt nhất cho khách hàng.</p>
                            
                            <div class="team-stats">
                                <div class="stat-item">
                                    <div class="stat-number">50+</div>
                                    <div class="stat-label">Nhân viên</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-number">10+</div>
                                    <div class="stat-label">Phòng ban</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-number">15+</div>
                                    <div class="stat-label">Chuyên gia</div>
                                </div>
                            </div>
                            
                            <a href="#" class="btn btn-team">Xem đội ngũ</a>
                        </div>
                    </div>
                </div>
                
                <!-- Card Công Ty -->
                <div class="col-md-4">
                    <div class="card custom-card company-card">
                        <div class="card-body">
                            <h5 class="card-title">Về Công Ty Chúng Tôi</h5>
                            <p class="card-text">Tiên phong trong việc hỗ trợ nhà ở và văn phòng cho thuê lớn nhất Việt Nam.</p>
                            
                            <div class="stats">
                                <div class="stat-item">
                                    <div class="stat-number">15+</div>
                                    <div class="stat-label">Năm kinh nghiệm</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-number">200+</div>
                                    <div class="stat-label">Dự án thành công</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-number">50+</div>
                                    <div class="stat-label">Nhân viên</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>


<script src="~/js/site.js"></script>
