<!-- Views/Admin/_AdminLayout.cshtml -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/Admin.css" />
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <nav class="admin-sidebar">
            <div class="sidebar-header">
                <h3>Admin Panel</h3>
            </div>
            
            <div class="admin-info">
                <i class="fas fa-user-circle fa-2x"></i>
                <div>
                    <strong>@ViewBag.AdminName</strong><br>
                    <small>@ViewBag.AdminEmail</small>
                </div>
            </div>
            
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")"
                           href="@Url.Action("Index", "Admin")">
                        <i class="fas fa-dashboard"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Users" ? "active" : "")"
                           href="@Url.Action("Users", "Admin")">
                        <i class="fas fa-users"></i> Quản lý người dùng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Auctions" ? "active" : "")"
                           href="@Url.Action("Auctions", "Admin")">
                        <i class="fas fa-gavel"></i> Quản lý đấu giá
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Deposits" ? "active" : "")"
                           href="@Url.Action("Deposits", "Admin")">
                        <i class="fas fa-money-bill"></i> Quản lý đặt cọc
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Reports" ? "active" : "")"
                           href="@Url.Action("Reports", "Admin")">
                        <i class="fas fa-chart-bar"></i> Báo cáo
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Settings" ? "active" : "")"
                           href="@Url.Action("Settings", "Admin")">
                        <i class="fas fa-gear"></i> Cài đặt
                    </a>
                </li>
                <li class="nav-item mt-4">
                    <a class="nav-link text-danger" href="@Url.Action("Logout", "Account")">
                        <i class="fas fa-sign-out-alt"></i> Đăng xuất
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Main Content -->
        <main class="admin-content">
            <!-- Hiển thị thông báo -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <script>
        // Kiểm tra session bằng JavaScript
        $(document).ready(function() {
        console.log("Admin page loaded");
            
        // Ping server để giữ session
        setInterval(function() {
        $.get('@Url.Action("KeepSession", "Admin")', function() {
        console.log("Session kept alive");
        });
        }, 60000); // 60 giây
        });
    </script>
</body>
</html>