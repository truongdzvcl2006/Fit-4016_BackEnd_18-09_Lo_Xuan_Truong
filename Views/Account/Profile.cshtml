@model RealEstateAuction.Models.User

@{
    // Sửa đường dẫn layout
    Layout = "~/Views/Home/_HomeLayout.cshtml";  // Đường dẫn đầy đủ
    ViewData["Title"] = "Thông tin cá nhân";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    .profile-container {
        max-width: 800px;
        margin: 100px auto 50px;
        padding: 20px;
    }
    .profile-card {
        background: white;
        border-radius: 10px;
        box-shadow: 0 0 20px rgba(0,0,0,0.1);
        overflow: hidden;
    }
    .profile-header {
        background: #4e73df;
        color: white;
        padding: 30px;
        text-align: center;
    }
    .profile-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: white;
        margin: 0 auto 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        color: #4e73df;
        border: 3px solid white;
    }
    .profile-name {
        font-size: 24px;
        margin-bottom: 5px;
    }
    .profile-email {
        font-size: 14px;
        opacity: 0.9;
    }
    .profile-badge {
        display: inline-block;
        background: rgba(255,255,255,0.2);
        padding: 5px 15px;
        border-radius: 20px;
        margin-top: 10px;
    }
    .profile-content {
        padding: 30px;
    }
    .info-row {
        display: flex;
        margin-bottom: 15px;
        padding: 10px;
        border-bottom: 1px solid #eee;
    }
    .info-label {
        width: 150px;
        font-weight: 600;
        color: #555;
    }
    .info-value {
        flex: 1;
        color: #333;
    }
    .btn-save {
        background: #4e73df;
        color: white;
        border: none;
        padding: 10px 30px;
        border-radius: 5px;
        cursor: pointer;
        margin-right: 10px;
    }
    .btn-save:hover {
        background: #2e59d9;
    }
    .alert {
        padding: 15px;
        border-radius: 5px;
        margin-bottom: 20px;
    }
    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }
    .alert-danger {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }
    .form-group {
        margin-bottom: 20px;
    }
    .form-control {
        width: 100%;
        padding: 10px;
        border: 1px solid #ddd;
        border-radius: 5px;
    }
    .form-control:focus {
        outline: none;
        border-color: #4e73df;
    }
</style>

<div class="profile-container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        </div>
    }

    <div class="profile-card">
        <div class="profile-header">
            <div class="profile-avatar">
                <i class="fas fa-user-circle"></i>
            </div>
            <h2 class="profile-name">@Model.FullName</h2>
            <div class="profile-email">@Model.Email</div>
            <div class="profile-badge">
                @if (Model.RoleId == 1)
                {
                    <i class="fas fa-crown"></i> <span>Quan tri vien</span>
                }
                else
                {
                    <i class="fas fa-user"></i> <span>Thanh vien</span>
                }
            </div>
        </div>

        <div class="profile-content">
            <!-- Form cập nhật thông tin -->
            <form asp-action="UpdateProfile" asp-controller="Account" method="post">
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="form-group">
                    <label><i class="fas fa-user"></i> Ho va ten</label>
                    <input type="text" class="form-control" name="fullName" value="@Model.FullName" required>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-phone"></i> So dien thoai</label>
                    <input type="tel" class="form-control" name="phone" value="@Model.Phone">
                </div>

                <div class="form-group">
                    <label><i class="fas fa-map-marker-alt"></i> Dia chi</label>
                    <input type="text" class="form-control" name="address" value="@Model.Address">
                </div>

                <div class="form-group">
                    <label><i class="fas fa-calendar"></i> Ngay tham gia</label>
                    <input type="text" class="form-control" value="@Model.CreatedAt.ToString("dd/MM/yyyy")" readonly disabled>
                </div>

                <button type="submit" class="btn-save">
                    <i class="fas fa-save"></i> Cap nhat
                </button>
                <a href="@Url.Action("Index", "Home")" class="btn-save" style="background: #858796;">
                    <i class="fas fa-home"></i> Trang chu
                </a>
            </form>

            <hr style="margin: 30px 0;">

            <!-- Form đổi mật khẩu đơn giản -->
            <h4>Doi mat khau</h4>
            <form asp-action="ChangePassword" asp-controller="Account" method="post">
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="form-group">
                    <label><i class="fas fa-lock"></i> Mat khau cu</label>
                    <input type="password" class="form-control" name="currentPassword" required>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-key"></i> Mat khau moi</label>
                    <input type="password" class="form-control" name="newPassword" required>
                </div>

                <div class="form-group">
                    <label><i class="fas fa-check"></i> Xac nhan mat khau moi</label>
                    <input type="password" class="form-control" name="confirmPassword" required>
                </div>

                <button type="submit" class="btn-save" style="background: #f6c23e;">
                    <i class="fas fa-key"></i> Doi mat khau
                </button>
            </form>
        </div>
    </div>
</div>