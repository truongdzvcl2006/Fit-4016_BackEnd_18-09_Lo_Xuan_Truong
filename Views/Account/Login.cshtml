@{
    ViewData["Title"] = "Đăng nhập / Đăng ký";
}

<link rel="stylesheet" href="~/css/auth.css" />


@if (ViewBag.Error != null)
{
    <div style="background: #f8d7da; color: #721c24; padding: 15px; margin: 20px auto; max-width: 400px; border-radius: 5px; text-align: center; border: 1px solid #f5c6cb;">
        <strong>LỖI:</strong> @ViewBag.Error
    </div>
}

@if (ViewBag.Success != null)
{
    <div style="background: #d4edda; color: #155724; padding: 15px; margin: 20px auto; max-width: 400px; border-radius: 5px; text-align: center; border: 1px solid #c3e6cb;">
        <strong>THÀNH CÔNG:</strong> @ViewBag.Success
    </div>
}

<div class="section">
    <div class="container">
        <div class="row full-height justify-content-center">
            <div class="col-12 text-center align-self-center py-5">
                <div class="section pb-5 pt-5 pt-sm-2 text-center">

                    <h6 class="mb-0 pb-3">
                        <span>Đăng nhập </span>
                        <span>Đăng ký</span>
                    </h6>

                    <input class="checkbox" type="checkbox" id="reg-log" name="reg-log" />
                    <label for="reg-log"></label>

                    <div class="card-3d-wrap mx-auto">
                        <div class="card-3d-wrapper">

                            <!-- Hiển thị thông báo -->
                            @if (ViewBag.Error != null)
                            {
                                <div class="alert alert-danger" style="background: #f8d7da; color: #721c24; padding: 10px; border-radius: 5px; margin: 10px;">
                                    @ViewBag.Error
                                </div>
                            }

                            @if (ViewBag.Success != null)
                            {
                                <div class="alert alert-success" style="background: #d4edda; color: #155724; padding: 10px; border-radius: 5px; margin: 10px;">
                                    @ViewBag.Success
                                </div>
                            }

                            <!-- FORM ĐĂNG NHẬP -->
                            <div class="card-front">
                                <div class="center-wrap">
                                    <div class="section text-center">
                                        <h4 class="mb-4 pb-3">Đăng nhập</h4>

                                        <form asp-controller="Account" asp-action="Login" method="post">
                                            <div class="form-group">
                                                <input type="email" name="email" class="form-style" placeholder="Email" required>
                                                <i class="input-icon uil uil-at"></i>
                                            </div>

                                            <div class="form-group mt-2">
                                                <input type="password" name="password" class="form-style" placeholder="Mật khẩu" required>
                                                <i class="input-icon uil uil-lock-alt"></i>
                                            </div>

                                            <button type="submit" class="btn mt-4">Đăng nhập</button>
                                        </form>

                                        <p class="mb-0 mt-4 text-center">
                                            <a href="#" class="link">Quên mật khẩu?</a>
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- FORM ĐĂNG KÝ -->
                            <div class="card-back">
                                <div class="center-wrap">
                                    <div class="section text-center">
                                        <h4 class="mb-3 pb-3">Đăng ký tài khoản</h4>

                                        <form asp-controller="Account" asp-action="Register" method="post">
                                            <div class="form-group">
                                                <input type="text" name="fullName" class="form-style" placeholder="Họ và tên *" required>
                                                <i class="input-icon uil uil-user"></i>
                                            </div>

                                            <div class="form-group mt-2">
                                                <input type="email" name="email" class="form-style" placeholder="Email *" required>
                                                <i class="input-icon uil uil-at"></i>
                                            </div>

                                            <div class="form-group mt-2">
                                                <input type="text" name="username" class="form-style" placeholder="Tên đăng nhập (không bắt buộc)">
                                                <i class="input-icon uil uil-user-circle"></i>
                                            </div>

                                            <div class="form-group mt-2">
                                                <input type="tel" name="phone" class="form-style" placeholder="Số điện thoại">
                                                <i class="input-icon uil uil-phone"></i>
                                            </div>

                                            <div class="form-group mt-2">
                                                <input type="password" name="password" class="form-style" placeholder="Mật khẩu *" required>
                                                <i class="input-icon uil uil-lock-alt"></i>
                                            </div>

                                            <button type="submit" class="btn mt-4">Đăng ký</button>
                                        </form>

                                        <p class="mb-0 mt-4 text-center text-muted">
                                            Bằng việc đăng ký, bạn đồng ý với 
                                            <a href="#" class="link">Điều khoản</a>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>